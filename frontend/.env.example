# Production API URL (your Vercel backend deployment, no trailing slash)
# Example: https://job-url-copier-api.vercel.app
# VITE_API_URL=https://job-url-copier-api.vercel.app

# Option A (two projects): set VITE_API_URL to the backend project URL above.
# Option B (one Services project): leave VITE_API_URL unset — /api is same origin.
# Local dev: leave unset — Vite proxies /api to http://localhost:3000
