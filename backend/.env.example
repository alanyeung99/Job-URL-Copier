PORT=3000
API_KEY=change-me-to-a-long-random-secret

# MongoDB Atlas connection string (required on Vercel — localhost will not work)
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/job-url-copier

# Platform session JWT (generate a long random string)
JWT_SECRET=change-me-to-a-long-random-jwt-secret
JWT_EXPIRES_IN=30d

# Comma-separated allowed dashboard origins (no trailing slash)
# Local: http://localhost:5173
# Vercel: https://your-frontend.vercel.app
CORS_ORIGIN=http://localhost:5173

# Google OAuth Web client (Credentials → OAuth 2.0 Client IDs → Web application)
GOOGLE_CLIENT_ID=403888653615-di3shbbj4f2sc3k2ai5me54licrua5rm.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=

